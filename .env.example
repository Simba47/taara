# ============================================================
# TAARA — Environment Variables
# ============================================================
# STEP 1: Copy this file → rename it to .env
# STEP 2: Fill in your real values from Supabase dashboard
# STEP 3: NEVER commit .env to git (it's already in .gitignore)
# STEP 4: Add the same keys in Vercel → Project Settings → Environment Variables
# ============================================================

# ── SUPABASE ────────────────────────────────────────────────
# Go to: https://supabase.com → Your Project → Settings → API

# Your project URL (looks like: https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your anon/public key (safe to use in the browser)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── HOW TO FIND THESE ───────────────────────────────────────
# 1. Go to https://supabase.com and sign in
# 2. Open your project
# 3. Click "Settings" (gear icon) in the left sidebar
# 4. Click "API" under Configuration
# 5. Copy "Project URL" → paste as VITE_SUPABASE_URL
# 6. Copy "anon public" key → paste as VITE_SUPABASE_ANON_KEY
#    (Do NOT use the service_role key — that has full DB access)
# ============================================================
